# CineSync backend — plantilla de variables de entorno.
# Copia a `.env` y completa los valores.

# --- Base de datos (host "db" = servicio de docker-compose) ---
DATABASE_URL=postgresql+asyncpg://cinesync:cinesync@db:5432/cinesync

# --- JWT ---
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- TMDB ---
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# --- Seed inicial de administrador (idempotente) ---
SEED_ADMIN_EMAIL=admin@cinesync.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NOMBRE=Administrador

# --- App ---
DEBUG=false
